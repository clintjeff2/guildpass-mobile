{
  "expo": {
    "name": "GuildPass",
    "slug": "guildpass-mobile",
    "version": "1.0.0",
    "scheme": "guildpass",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "xyz.guildpass.mobile",
      "infoPlist": {
        "CFBundleDisplayName": "GuildPass",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["guildpass"]
          }
        ]
      },
      "associatedDomains": [
        "applinks:guildpass.xyz"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "xyz.guildpass.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "guildpass"
            },
            {
              "scheme": "https",
              "host": "guildpass.xyz"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/your-project-id",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GuildPass to scan access check QR codes."
        }
      ]
    ]
  }
}
